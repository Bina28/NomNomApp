{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=nomnom;Username=postgres;Password=postgres"
  },

  "SpoonacularApi": {
    "ApiKey": "your_spoonacular_api_key_here",
    "BaseUrl": "https://api.spoonacular.com/"
  },

  "CloudinarySettings": {
    "CloudName": "your_cloud_name",
    "ApiKey": "your_cloudinary_api_key",
    "ApiSecret": "your_cloudinary_api_secret"
  },

  "JwtSettings": {
    "Key": "your_secret_key_minimum_64_characters_long_replace_this_with_a_real_secret",
    "Issuer": "NomNomApi",
    "Audience": "NomNomClient",
    "ExpiryMinutes": 15
  },

  "AllowedHosts": "*"
}
